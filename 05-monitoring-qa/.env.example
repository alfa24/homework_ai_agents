# Telegram Bot Configuration
TELEGRAM_TOKEN=

# SOCKS5 Proxy Configuration (optional)
PROXY_URL=socks5://user:password@host:port
# Or without authentication:
# PROXY_URL=socks5://host:port

# OpenRouter / Ollama Configuration
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
MODEL_TEXT=openai/gpt-oss-20b:free
MODEL_IMAGE=qwen/qwen2.5-vl-32b-instruct
MODEL_AUDIO=openai/gpt-audio-mini

# Ollama Configuration
#OPENAI_API_KEY=ollama
#OPENAI_BASE_URL=http://IP:11434/v1
#MODEL_TEXT=gpt-oss:20b
#MODEL_IMAGE=qwen3-vl:8b-instruct
# MODEL_AUDIO не используется: Ollama не поддерживает audio input.
# Обработка голосовых сообщений доступна только через провайдеров с поддержкой audio input (RouterAI, OpenAI).

# System Prompt
# Путь к файлу с промптом (относительно корня проекта)
SYSTEM_PROMPT_PATH=prompts/system_prompt.txt

# RAG Assistant (Sprint 2)
# RAG-команды (/ask, /ask_reset, /index, /index_status) требуют OpenRouter/OpenAI-совместимого провайдера (нужен embeddings API).
# Через Ollama RAG в MVP не поддерживается.
MODEL_CHAT_RAG=openai/gpt-4o-mini
MODEL_EMBEDDINGS=openai/text-embedding-3-small
DATA_DIR=data
RETRIEVER_K=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# RAG sources display
SHOW_SOURCES=false

# Langfuse tracing (optional)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# RAGAS evaluation (итерация 4)
RAGAS_LLM_MODEL=deepseek/deepseek-v4-pro
RAGAS_EMBEDDING_MODEL=openai/text-embedding-3-small
