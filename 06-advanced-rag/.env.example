# Telegram Bot Configuration
TELEGRAM_TOKEN=

# SOCKS5 Proxy Configuration (optional)
# PROXY_URL=socks5://user:password@host:port

# OpenRouter / Ollama Configuration
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
MODEL_TEXT=openai/gpt-oss-20b:free
MODEL_IMAGE=qwen/qwen2.5-vl-32b-instruct
MODEL_AUDIO=openai/gpt-audio-mini

# Ollama Configuration
#OPENAI_API_KEY=ollama
#OPENAI_BASE_URL=http://IP:11434/v1
#MODEL_TEXT=gpt-oss:20b
#MODEL_IMAGE=qwen3-vl:8b-instruct
# MODEL_AUDIO не используется: Ollama не поддерживает audio input.
# Обработка голосовых сообщений доступна только через провайдеров с поддержкой audio input (RouterAI, OpenAI).

# System Prompt
# Путь к файлу с промптом (относительно корня проекта)
SYSTEM_PROMPT_PATH=prompts/system_prompt.txt

# RAG Assistant
MODEL_CHAT_RAG=openai/gpt-4o-mini
DATA_DIR=data
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Advanced RAG: semantic | hybrid | hybrid_rerank
RAG_RETRIEVAL_MODE=semantic
EMBEDDINGS_PROVIDER=openai
MODEL_EMBEDDINGS=openai/text-embedding-3-small
SEMANTIC_RETRIEVER_K=4
BM25_RETRIEVER_K=8
HYBRID_RETRIEVER_K=8
HYBRID_SEMANTIC_WEIGHT=0.5
HYBRID_BM25_WEIGHT=0.5
MODEL_CROSS_ENCODER=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANKER_TOP_K=4

# RAG sources display
SHOW_SOURCES=false

# Langfuse tracing (optional)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# RAGAS evaluation
MODEL_RAGAS_LLM=openai/gpt-oss-20b:free
RAGAS_EMBEDDINGS_PROVIDER=openai
MODEL_RAGAS_EMBEDDINGS=openai/text-embedding-3-small
